#include <iostream>
#include <sstream>
#include <cmath>
#include <vector>
#include <string>
#include <algorithm>
#include <set>
#include "lang.h"
#include "transform.h"
#include "visitor.h"

extern std::vector<std::string> global_trace;

// --- Cheat ---
class Cheat : public Transform {
  std::set<std::string> user_funcs;
public:
  Program *transformProgram(Program *node) override {
    for (auto decl : node->body) {
      user_funcs.insert(decl->name);
    }
    std::vector<FunctionDeclaration *> body;
    for (auto decl : node->body) {
      body.push_back(transformFunctionDeclaration(decl));
    }
    return new Program(body);
  }

  FunctionDeclaration *transformFunctionDeclaration(FunctionDeclaration *node) override {
    std::vector<Variable *> params;
    for (auto param : node->params) {
      params.push_back(transformVariable(param));
    }
    std::string new_name = node->name;
    if (new_name != "main") {
      new_name = "f_" + new_name;
    }
    return new FunctionDeclaration(new_name, params, transformStatement(node->body));
  }

  Variable *transformVariable(Variable *node) override {
    return new Variable("v_" + node->name);
  }

  Expression *transformIntegerLiteral(IntegerLiteral *node) override {
    // x -> (+ x 0)
    return new CallExpression("+", {new IntegerLiteral(node->value), new IntegerLiteral(0)});
  }

  Expression *transformCallExpression(CallExpression *node) override {
    std::vector<Expression *> args;
    for (auto arg : node->args) {
      args.push_back(transformExpression(arg));
    }
    std::string func_name = node->func;
    if (func_name == "+" || func_name == "*" || func_name == "==" || func_name == "!=" || func_name == "||" || func_name == "&&") {
      if (args.size() == 2) {
        std::swap(args[0], args[1]);
      }
    } else if (func_name == "<") {
      func_name = ">";
      std::swap(args[0], args[1]);
    } else if (func_name == ">") {
      func_name = "<";
      std::swap(args[0], args[1]);
    } else if (func_name == "<=") {
      func_name = ">=";
      std::swap(args[0], args[1]);
    } else if (func_name == ">=") {
      func_name = "<=";
      std::swap(args[0], args[1]);
    } else if (user_funcs.count(func_name)) {
      func_name = "f_" + func_name;
    }
    return new CallExpression(func_name, args);
  }

  Statement *transformBlockStatement(BlockStatement *node) override {
    std::vector<Statement *> body;
    for (auto stmt : node->body) {
      body.push_back(transformStatement(stmt));
      // Add a dummy statement
      body.push_back(new SetStatement(new Variable("dummy_var"), new IntegerLiteral(0)));
    }
    return new BlockStatement(body);
  }
};

// --- Anticheat ---
class TokenExtractor : public Visitor<int> {
public:
  std::vector<std::string> tokens;

  int visitFunctionDeclaration(FunctionDeclaration *node) override {
    tokens.push_back("Func");
    visitStatement(node->body);
  }

  int visitExpressionStatement(ExpressionStatement *node) override {
    visitExpression(node->expr);
  }
  int visitSetStatement(SetStatement *node) override {
    tokens.push_back("Set");
    visitExpression(node->value);
  }
  int visitIfStatement(IfStatement *node) override {
    tokens.push_back("If");
    visitExpression(node->condition);
    visitStatement(node->body);
  }
  int visitForStatement(ForStatement *node) override {
    tokens.push_back("For");
    visitStatement(node->init);
    visitExpression(node->test);
    visitStatement(node->update);
    visitStatement(node->body);
  }
  int visitBlockStatement(BlockStatement *node) override {
    for (auto stmt : node->body) {
      visitStatement(stmt);
    }
  }
  int visitReturnStatement(ReturnStatement *node) override {
    tokens.push_back("Ret");
    visitExpression(node->value);
  }

  int visitIntegerLiteral(IntegerLiteral *node) override {
    // Ignore
  }
  int visitVariable(Variable *node) override {
    // Ignore
  }
  int visitCallExpression(CallExpression *node) override {
    std::string f = node->func;
    if (f == "+" || f == "-" || f == "*" || f == "/" || f == "%" ||
        f == "<" || f == ">" || f == "<=" || f == ">=" || f == "==" || f == "!=" ||
        f == "||" || f == "&&" || f == "!") {
      tokens.push_back("Op");
    } else if (f == "scan" || f == "print" || f == "array.create" || f == "array.scan" || f == "array.print" || f == "array.get" || f == "array.set") {
      tokens.push_back(f);
    } else {
      tokens.push_back("Call");
    }
    for (auto expr : node->args) {
      visitExpression(expr);
    }
  }
};

int edit_distance(const std::vector<std::string>& a, const std::vector<std::string>& b) {
  int n = a.size();
  int m = b.size();
  std::vector<std::vector<int>> dp(n + 1, std::vector<int>(m + 1));
  for (int i = 0; i <= n; ++i) dp[i][0] = i;
  for (int j = 0; j <= m; ++j) dp[0][j] = j;
  for (int i = 1; i <= n; ++i) {
    for (int j = 1; j <= m; ++j) {
      if (a[i - 1] == b[j - 1]) {
        dp[i][j] = dp[i - 1][j - 1];
      } else {
        dp[i][j] = 1 + std::min({dp[i - 1][j], dp[i][j - 1], dp[i - 1][j - 1]});
      }
    }
  }
  return dp[n][m];
}

double get_similarity(const std::vector<std::string>& a, const std::vector<std::string>& b) {
  if (a.empty() && b.empty()) return 1.0;
  int dist = edit_distance(a, b);
  return 1.0 - (double)dist / std::max({1, (int)a.size(), (int)b.size()});
}

int main() {
  auto code1 = scanProgram(std::cin);
  std::cin >> std::ws;
  if (std::cin.peek() == EOF) {
    // Cheat mode
    auto cheat = Cheat().transformProgram(code1);
    std::cout << cheat->toString();
  } else {
    // Anticheat mode
    auto code2 = scanProgram(std::cin);
    std::string input;
    int c;
    while ((c = std::cin.get()) != EOF) {
      input += c;
    }

    // 1. AST Token Similarity
    TokenExtractor te1, te2;
    te1.visitProgram(code1);
    te2.visitProgram(code2);
    double sim_ast = get_similarity(te1.tokens, te2.tokens);

    // 2. Trace Similarity
    std::istringstream iss1(input);
    std::ostringstream oss1;
    global_trace.clear();
    try {
      code1->eval(1000000, iss1, oss1);
    } catch (...) {}
    std::vector<std::string> trace1 = global_trace;

    std::istringstream iss2(input);
    std::ostringstream oss2;
    global_trace.clear();
    try {
      code2->eval(1000000, iss2, oss2);
    } catch (...) {}
    std::vector<std::string> trace2 = global_trace;

    double sim_trace = get_similarity(trace1, trace2);

    double sim = std::max(sim_ast, sim_trace);

    double score;
    if (sim > 0.7) {
      score = 0.99;
    } else if (sim < 0.4) {
      score = 0.01;
    } else {
      score = sim;
    }
    std::cout << score << std::endl;
  }
  return 0;
}